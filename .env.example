# YusBuild Environment Configuration
# Copy to .env and update values for your environment

# Django
DJANGO_SECRET_KEY="replace-with-a-long-random-secret"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.yusbuild.ng

# PostgreSQL
POSTGRES_DB=yusbuild
POSTGRES_USER=yusbuild_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Logging
LOG_LEVEL=INFO
